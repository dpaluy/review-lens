#!/usr/bin/env bash
set -euo pipefail

case "${KAMAL_COMMAND:-}" in
  rollback)
    exit 0
    ;;
esac

export DOCR_REGISTRY="${DOCR_REGISTRY:-reviewlens}"
export DOCR_REPOSITORY="${DOCR_REPOSITORY:-review_lens}"
export DOCR_KEEP_MANIFESTS="${DOCR_KEEP_MANIFESTS:-1}"
export DOCR_WAIT_GC="${DOCR_WAIT_GC:-1}"

echo "Pruning DigitalOcean Container Registry before Kamal build..."
bin/prune-docr-repository
