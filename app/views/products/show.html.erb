<main>
  <h1><%= @product.name.presence || @product.external_id %></h1>

  <% if @product.thin_corpus? %>
    <section data-testid="thin-corpus-warning" role="alert">
      <h2>Thin corpus</h2>

      <p>
        Only <%= pluralize(@product.usable_review_count, "usable review") %> available.
        ReviewLens needs least <%= Product::MINIMUM_USABLE_REVIEW_COUNT %> usable reviews for grounded answers.
      </p>
    </section>
  <% end %>

  <% if @ingestion_run.warning_messages.any? %>
    <section data-testid="parser-warnings" role="alert">
      <h2>Parser warnings</h2>

      <ul>
        <% @ingestion_run.warning_messages.each do |warning_message| %>
          <li><%= warning_message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <dl>
    <dt>Platform</dt>
    <dd><%= @product.platform %></dd>

    <dt>Source URL</dt>
    <dd><%= @product.source_url %></dd>

    <dt>Product status</dt>
    <dd><%= @product.ingestion_status %></dd>

    <dt>Run status</dt>
    <dd><%= @ingestion_run.status %></dd>

    <dt>Usable reviews</dt>
    <dd><%= @product.usable_review_count %></dd>

    <dt>Pages attempted</dt>
    <dd><%= @ingestion_run.pages_attempted %></dd>

    <dt>Pages succeeded</dt>
    <dd><%= @ingestion_run.pages_succeeded %></dd>

    <dt>Reviews found</dt>
    <dd><%= @ingestion_run.reviews_found %></dd>

    <dt>Reviews imported</dt>
    <dd><%= @ingestion_run.reviews_imported %></dd>

    <dt>Reviews skipped</dt>
    <dd><%= @ingestion_run.reviews_skipped %></dd>
  </dl>

  <% failure_message = @ingestion_run.error.presence || @product.ingestion_error.presence %>
  <% if failure_message.present? %>
    <section>
      <h2>Failure</h2>

      <p><%= failure_message %></p>
    </section>
  <% end %>
</main>
