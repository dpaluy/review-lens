<% assistant ||= local_assigns[:message] || local_assigns[:chat_message] %>
<% metadata = assistant.answer_metadata %>
<div id="chat_message_<%= assistant.id %>" class="w-full sm:w-auto my-5 space-y-3 rounded-md px-3 py-2 bg-green-50">
  <div>
    <span class="inline-block rounded px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700">
      Assistant
    </span>
  </div>

  <div id="chat_message_<%= assistant.id %>_content" class="rl-markdown"><%= format_markdown(assistant.content) %></div>

  <% if metadata["supporting_review_ids"].present? %>
    <div class="space-y-2 text-sm text-gray-700">
      <p>Supporting reviews: <%= metadata["supporting_review_ids"].join(", ") %></p>
    </div>
  <% end %>

  <div>
    <span class="text-sm text-gray-600"><%= assistant.created_at&.strftime("%I:%M %p") %></span>
  </div>
</div>
