<% if defined?(@product) && @product.present? %>
  <%= turbo_stream.remove "product_chat_empty" %>
  <%= turbo_stream.remove "product_chat_pending" %>
  <% if defined?(@user_message) && @user_message.present? %>
    <%= turbo_stream.append "chat_messages" do %>
      <%= render @user_message %>
    <% end %>
    <%= turbo_stream.append "chat_messages" do %>
      <%= render "products/chat_pending" %>
    <% end %>
  <% end %>
  <%= turbo_stream.replace "product_chat_form" do %>
    <%= render "products/chat_form", product: @product, disabled: true %>
  <% end %>
<% elsif defined?(@conversation) && @conversation.present? %>
  <%= turbo_stream.replace "new_chat_message" do %>
    <%= render "chat_messages/form",
      conversation: @conversation,
      chat_message: @conversation.chat_messages.build %>
  <% end %>
<% end %>
